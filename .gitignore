# Knowledge base (generated per-user, content only)
wiki/sources/*.md
wiki/entities/*.md
wiki/concepts/*.md
wiki/health-report.md
wiki/lint-report.md
wiki/validation-report.md

# Graph (auto-generated)
graph/*
!graph/.gitkeep

# Raw documents (private)
raw/*
!raw/.gitkeep

# Converter staging (temporary scripts, auto-cleaned)
.staging/*
!.staging/.gitkeep

# Dependency markers (auto-generated by /janus-setup and /privacy-mode)
.deps-ok
.privacy-deps-ok

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# OS
Thumbs.db
.DS_Store
desktop.ini

# Claude Code local settings (machine-specific permissions)
.claude/settings.local.json

# Editor / notes
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~
